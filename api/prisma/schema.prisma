generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Organization {
  id                          String   @id @default(cuid())
  name                        String
  slug                        String   @unique
  logoUrl                     String?
  ghlApiBaseUrl               String?
  ghlLocationId               String?
  ghlAccessToken              String?
  ghlContactSyncMaxPages      Int?
  ghlVisitsObjectKey          String?
  ghlVisitsFieldClientNameKey String?
  ghlVisitsFieldOwnerKey      String?
  ghlVisitsFieldVisitDateKey  String?
  ghlVisitsFieldNotesKey      String?
  ghlVisitsFieldTitleKey      String?
  createdAt                   DateTime @default(now())
  updatedAt                   DateTime @updatedAt
  users                       User[]
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  username  String   @unique
  passwordHash String?
  role      String   @default("SELLER")
  ghlUserId String?
  organizationId String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  visits    Visit[]
  clients   Client[]
  ghlContacts GhlContact[]
  ghlOpportunities GhlOpportunity[]
  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId, role])
}

model Client {
  id           String   @id @default(cuid())
  name         String
  externalRef  String?  @unique
  ghlContactId String?  @unique
  sellerId     String?
  seller       User?    @relation(fields: [sellerId], references: [id])
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  visits       Visit[]
}

model Visit {
  id               String    @id @default(cuid())
  localVisitId     String    @unique
  sellerId         String
  clientId         String
  notes            String
  checkInAt        DateTime
  latitude         Float
  longitude        Float
  accuracyMeters   Float?
  syncedAt         DateTime?
  status           VisitStatus @default(PENDING)
  ghlNoteId        String?
  lastSyncError    String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  seller User   @relation(fields: [sellerId], references: [id])
  client Client @relation(fields: [clientId], references: [id])
}

model GhlContact {
  id                String   @id @default(cuid())
  sellerId          String
  ghlContactId      String
  name              String
  email             String?
  phone             String?
  ownerUserId       String?
  sourceUpdatedAt   DateTime?
  lastSyncedAt      DateTime @default(now())
  rawJson           Json?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  seller        User             @relation(fields: [sellerId], references: [id])
  opportunities GhlOpportunity[]

  @@unique([sellerId, ghlContactId])
  @@index([sellerId, name])
}

model GhlOpportunity {
  id                 String   @id @default(cuid())
  sellerId           String
  ghlOpportunityId   String
  ghlContactId       String?
  title              String?
  status             String?
  stageId            String?
  stageName          String?
  monetaryValue      Float?
  sourceUpdatedAt    DateTime?
  lastSyncedAt       DateTime @default(now())
  rawJson            Json?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  seller  User       @relation(fields: [sellerId], references: [id])
  contact GhlContact? @relation(fields: [sellerId, ghlContactId], references: [sellerId, ghlContactId])

  @@unique([sellerId, ghlOpportunityId])
  @@index([sellerId, ghlContactId])
}

model SyncCursor {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

enum VisitStatus {
  PENDING
  SYNCED
  FAILED
}
